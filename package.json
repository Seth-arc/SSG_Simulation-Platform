{
  "name": "esg-simulation-platform",
  "version": "2.0.0",
  "description": "ESG Economic Statecraft Simulation Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --host 127.0.0.1 --port 4174 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vitest/vitest.mjs run",
    "test:ui": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vitest/vitest.mjs --ui",
    "test:coverage": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "jszip": "^3.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "vite": "^5.4.21",
    "vitest": "^1.0.0"
  }
}
